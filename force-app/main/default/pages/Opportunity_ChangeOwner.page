<apex:page standardController="Lead__c"
           recordSetVar="records"
           extensions="SObjectChangeOwnerController"
           lightningStylesheets="true">

    <apex:form id="theForm">

        <!-- Spinner -->
        <apex:actionStatus id="status">
            <apex:facet name="start">
                <div class="slds-backdrop slds-backdrop_open"></div>
                <div class="slds-spinner slds-spinner_medium slds-spinner_brand" role="status">
                    <span class="slds-assistive-text">Updating...</span>
                    <div class="slds-spinner__dot-a"></div>
                    <div class="slds-spinner__dot-b"></div>
                </div>
            </apex:facet>
        </apex:actionStatus>

        <apex:pageBlock title="Change Record Owner" mode="edit">

            <apex:pageMessages id="msgs"/>

            <apex:pageBlockSection columns="1">
                
                <apex:pageBlockSectionItem >
                    <apex:outputLabel value="New Owner"/>
                    <apex:selectList value="{!selectedUserId}" size="1">
                        <apex:selectOptions value="{!users}" />
                    </apex:selectList>
                </apex:pageBlockSectionItem>
                
                <apex:pageBlockSectionItem >
                    <apex:outputLabel value="Reason for Owner Change"/>
                    <apex:inputTextarea value="{!changeReason}"
                                        rows="3"
                                        style="width:100%;"/>
                </apex:pageBlockSectionItem>
                
            </apex:pageBlockSection>


            <apex:pageBlockButtons location="bottom">

                <apex:commandButton value="Update Owner"
                                    action="{!updateOwner}"
                                    status="status"
                                    rerender="msgs"/>

                <apex:commandButton value="Cancel"
                                    onclick="window.history.back(); return false;"/>

            </apex:pageBlockButtons>

        </apex:pageBlock>

    </apex:form>
</apex:page>