<apex:page standardController="Lead__c"
           recordSetVar="records"
           extensions="BulkWebinarRegistrationController"
           lightningStylesheets="true">

    <apex:form >

        <!-- Spinner -->
        <apex:actionStatus id="status">
            <apex:facet name="start">
                <div class="slds-backdrop slds-backdrop_open"></div>
                <div class="slds-spinner slds-spinner_medium slds-spinner_brand" role="status">
                    <span class="slds-assistive-text">Processing...</span>
                    <div class="slds-spinner__dot-a"></div>
                    <div class="slds-spinner__dot-b"></div>
                </div>
            </apex:facet>
        </apex:actionStatus>

        <apex:pageBlock title="Bulk Webinar Registration">

            <apex:pageMessages />

            <apex:pageBlockSection columns="1">

                <apex:pageBlockSectionItem >
                    <apex:outputLabel value="Select Webinar"/>
                    <apex:selectList value="{!selectedWebinarId}" size="1">
                        <apex:selectOptions value="{!webinarOptions}" />
                    </apex:selectList>
                </apex:pageBlockSectionItem>

            </apex:pageBlockSection>

            <apex:pageBlockButtons location="bottom">

                <apex:commandButton value="Register"
                                    action="{!registerLeads}"
                                    status="status"
                                    rerender=""/>

                <apex:commandButton value="Cancel"
                                    onclick="window.history.back(); return false;"/>

            </apex:pageBlockButtons>

        </apex:pageBlock>

    </apex:form>
</apex:page>