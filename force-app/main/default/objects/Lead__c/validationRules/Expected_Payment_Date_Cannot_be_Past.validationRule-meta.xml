<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Expected_Payment_Date_Cannot_be_Past</fullName>
    <active>false</active>
    <errorConditionFormula>AND(
    NOT(ISBLANK(Expected_payment_date__c)),
    Expected_payment_date__c &lt; TODAY()
)</errorConditionFormula>
    <errorMessage>Expected Payment Date cannot be in the past.</errorMessage>
</ValidationRule>
