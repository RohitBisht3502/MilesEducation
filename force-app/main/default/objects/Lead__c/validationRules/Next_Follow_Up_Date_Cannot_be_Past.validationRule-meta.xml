<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Next_Follow_Up_Date_Cannot_be_Past</fullName>
    <active>false</active>
    <errorConditionFormula>AND(
    NOT(ISBLANK(Next_Follow_Up_Date__c)),
    Next_Follow_Up_Date__c &lt; NOW()
)</errorConditionFormula>
    <errorMessage>Next Follow Up Date cannot be in the past.</errorMessage>
</ValidationRule>
